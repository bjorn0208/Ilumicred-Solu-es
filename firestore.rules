rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // 1. Default-deny catch-all safety net
    match /{document=**} {
      allow read, write: if false;
    }

    // --- Helper Functions ---
    function isSignedIn() {
      return request.auth != null;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    function isValidUser(data) {
      return data.uid == request.auth.uid
          && data.email is string
          && data.email.size() <= 256;
    }

    function isValidSimulation(data) {
      return data.id is string
          && data.id.size() <= 128
          && data.name is string
          && data.name.size() >= 3
          && data.name.size() <= 100
          && data.telefone is string
          && data.telefone.size() <= 30
          && data.sonho is string
          && data.sonho.size() <= 100
          && data.servico is string
          && data.servico.size() <= 100
          && data.negativado is string
          && data.negativado.size() <= 20
          && data.valorDividas is string
          && data.valorDividas.size() <= 50
          && data.userId == request.auth.uid;
    }

    // --- Path Rules ---
    match /users/{userId} {
      // Split read and write to prevent Null Pointer Exceptions with incoming() on read
      allow read: if isSignedIn() && request.auth.uid == userId;
      allow create, update: if isSignedIn() && request.auth.uid == userId && isValidUser(incoming());
      
      match /simulations/{simulationId} {
        allow read: if isSignedIn() && request.auth.uid == userId;
        allow create: if isSignedIn() && request.auth.uid == userId && isValidSimulation(incoming()) && isValidId(simulationId);
        allow update: if isSignedIn() && request.auth.uid == userId && isValidSimulation(incoming()) && incoming().id == existing().id && incoming().userId == existing().userId;
        allow delete: if isSignedIn() && request.auth.uid == userId;
      }
    }
  }
}
